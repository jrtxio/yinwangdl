---
layout: base.njk
title: ""
pagination:
  data: collections.post
  size: 50
  alias: posts
permalink: "{% if pagination.pageNumber > 0 %}page/{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
---
<div class="home">
  <div class="ad-container">
    <ins class="adsbygoogle"
      style="display:block"
      data-ad-client="ca-pub-3215512126020129"
      data-ad-slot="7014497615"
      data-ad-format="auto"
      data-full-width-responsive="true"></ins>
    <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
  </div>

  {% set currentYear = "0000" %}
  {% for post in posts %}
    {% set postYear = post.data.created | year %}
    {% if postYear != currentYear %}
      {% if not loop.first %}</div>{% endif %}
      <div class="year-section">
        <div class="year-label">{{ postYear }}</div>
    {% set currentYear = postYear %}
    {% endif %}

    <div class="post-card">
      <div class="post-card-title">
        <a href="{{ post.url }}">{{ post.data.title or post.fileSlug }}</a>
      </div>
      {% if post.data.created %}
      <div class="post-card-date">{{ post.data.created | isodate }}</div>
      {% endif %}
    </div>

    {% if loop.last %}</div>{% endif %}
  {% endfor %}

  {% if pagination.pages.length > 1 %}
  <nav class="pagination">
    {% if pagination.previousPageLink %}
    <a href="{{ pagination.previousPageHref }}" class="prev">&larr; 上一页</a>
    {% endif %}
    {% if pagination.nextPageLink %}
    <a href="{{ pagination.nextPageHref }}" class="next">下一页 &rarr;</a>
    {% endif %}
  </nav>
  {% endif %}
</div>
