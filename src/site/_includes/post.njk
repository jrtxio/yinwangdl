---
layout: base.njk
---
<article class="post">
  <a href="/" class="post-back">&larr; 返回列表</a>
  <header class="post-header">
    <h1>{{ title }}</h1>
    <div class="post-meta">
      <span>{{ author or "王垠" }}</span>
      {% if created %}
      <span class="sep">&middot;</span>
      <time>{{ created | isodate }}</time>
      {% endif %}
      {% if source %}
      <span class="sep">&middot;</span>
      <a href="{{ source }}" target="_blank" rel="noopener">原文</a>
      {% endif %}
    </div>
  </header>
  <div class="post-content">
    {{ content | safe }}
  </div>
</article>
